#:import dp kivy.metrics.dp

<ChatScreen>

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(15)
        spacing: dp(15)

        canvas.before:
            Color:
                rgba: 0.04,0.05,0.09,1
            Rectangle:
                pos: self.pos
                size: self.size

        MDLabel:
            text: "Chat"
            halign: "center"
            font_style: "H5"

        MDCard:
            padding: dp(15)
            adaptive_height: True

            MDLabel:
                text: "Conversation will appear here."
                halign: "center"

        Widget

        MDTextField:
            hint_text: "Type a message"

        MDRaisedButton:
            text: "Send"
            pos_hint: {"center_x": .5}

#:import dp kivy.metrics.dp

<HomeScreen>

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(18)
        spacing: dp(18)

        canvas.before:
            Color:
                rgba: 0.05,0.06,0.10,1
            Rectangle:
                pos: self.pos
                size: self.size

        MDLabel:
            text: "AP AI"
            halign: "center"
            font_style: "H4"
            bold: True
            theme_text_color: "Custom"
            text_color: 0.0,0.75,1,1

        MDCard:
            orientation: "vertical"
            radius: [20]
            padding: dp(18)
            adaptive_height: True
            elevation: 4

            MDLabel:
                text: "Welcome, Amarchand"
                halign: "center"
                font_style: "H5"

            MDLabel:
                text: "Your Personal AI Assistant"
                halign: "center"
                theme_text_color: "Secondary"

        MDGridLayout:
            cols: 2
            spacing: dp(15)
            adaptive_height: True

            MDRaisedButton:
                text: "💬 Chat"

            MDRaisedButton:
                text: "🎤 Voice"

            MDRaisedButton:
                text: "🧠 Memory"

            MDRaisedButton:
                text: "🛠 Tools"

            MDRaisedButton:
                text: "⚙ Settings"

            MDRaisedButton:
                text: "📄 Notes"

        Widget

        MDLabel:
            text: "AP AI Android v2"
            halign: "center"
            theme_text_color: "Hint"

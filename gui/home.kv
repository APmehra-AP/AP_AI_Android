#:import dp kivy.metrics.dp

<HomeScreen>

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(20)

        canvas.before:
            Color:
                rgba: 0.04, 0.05, 0.09, 1
            Rectangle:
                pos: self.pos
                size: self.size

        MDLabel:
            text: "AP AI"
            halign: "center"
            font_style: "H4"
            bold: True
            theme_text_color: "Custom"
            text_color: 0, 0.75, 1, 1

        MDCard:
            orientation: "vertical"
            padding: dp(18)
            radius: [20]
            elevation: 4
            adaptive_height: True

            MDLabel:
                text: "Welcome"
                halign: "center"
                font_style: "H5"

            MDLabel:
                text: "Your Personal AI Assistant"
                halign: "center"
                theme_text_color: "Secondary"

        MDGridLayout:
            cols: 2
            spacing: dp(15)
            adaptive_height: True

            MDCard:
                ripple_behavior: True
                padding: dp(15)
                radius: [18]
                adaptive_height: True

                MDLabel:
                    text: "💬 Chat"
                    halign: "center"

            MDCard:
                ripple_behavior: True
                padding: dp(15)
                radius: [18]
                adaptive_height: True

                MDLabel:
                    text: "🎤 Voice"
                    halign: "center"

            MDCard:
                ripple_behavior: True
                padding: dp(15)
                radius: [18]
                adaptive_height: True

                MDLabel:
                    text: "🧠 Memory"
                    halign: "center"

            MDCard:
                ripple_behavior: True
                padding: dp(15)
                radius: [18]
                adaptive_height: True

                MDLabel:
                    text: "🛠 Tools"
                    halign: "center"

            MDCard:
                ripple_behavior: True
                padding: dp(15)
                radius: [18]
                adaptive_height: True

                MDLabel:
                    text: "⚙ Settings"
                    halign: "center"

            MDCard:
                ripple_behavior: True
                padding: dp(15)
                radius: [18]
                adaptive_height: True

                MDLabel:
                    text: "📄 Notes"
                    halign: "center"

        Widget

        MDLabel:
            text: "AP AI Phase 1"
            halign: "center"
            theme_text_color: "Hint"

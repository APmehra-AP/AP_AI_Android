#:import dp kivy.metrics.dp

<HomeScreen>

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(20)

        canvas.before:
            Color:
                rgba: 0.04, 0.05, 0.09, 1
            Rectangle:
                pos: self.pos
                size: self.size

        MDBoxLayout:
            adaptive_height: True
            padding: dp(10)

            MDLabel:
                text: "AP AI"
                halign: "center"
                font_style: "H4"
                bold: True
                theme_text_color: "Custom"
                text_color: 0.1, 0.8, 1, 1

        MDCard:
            orientation: "vertical"
            padding: dp(20)
            radius: [20]
            adaptive_height: True
            elevation: 3

            MDLabel:
                text: "Welcome"
                halign: "center"
                font_style: "H5"

            MDLabel:
                text: "Your Personal AI Assistant"
                halign: "center"
                theme_text_color: "Secondary"

        MDGridLayout:
            cols: 2
            spacing: dp(15)
            adaptive_height: True

            MDRaisedButton:
                text: "Chat"

            MDRaisedButton:
                text: "Voice"

            MDRaisedButton:
                text: "Memory"

            MDRaisedButton:
                text: "Tools"

            MDRaisedButton:
                text: "Settings"

            MDRaisedButton:
                text: "Notes"

        Widget

        MDLabel:
            text: "AP AI Android"
            halign: "center"
            theme_text_color: "Hint"

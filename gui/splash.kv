#:import dp kivy.metrics.dp

<SplashScreen>:

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(20)

        MDLabel:
            text: "AP AI"
            halign: "center"
            font_style: "H4"

        MDLabel:
            text: "Created by : Amarchand Meghwal"
            halign: "center"

        MDRaisedButton:
            text: "Open Home"
            pos_hint: {"center_x": .5}
            on_release:
                app.root.current = "home"

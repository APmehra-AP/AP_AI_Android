#:import dp kivy.metrics.dp

<SplashScreen>

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(30)
        spacing: dp(20)

        canvas.before:
            Color:
                rgba: 0.03, 0.05, 0.09, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Widget

        MDIcon:
            icon: "robot-outline"
            icon_size: "100sp"
            pos_hint: {"center_x": .5}
            theme_text_color: "Custom"
            text_color: 0.0, 0.75, 1.0, 1

        MDLabel:
            text: "AP AI"
            halign: "center"
            font_style: "H4"
            bold: True
            theme_text_color: "Custom"
            text_color: 0.0, 0.75, 1.0, 1

        MDLabel:
            text: "Your Personal AI Assistant"
            halign: "center"
            theme_text_color: "Secondary"

        MDProgressBar:
            value: 100

        MDLabel:
            text: "Loading..."
            halign: "center"
            theme_text_color: "Hint"

        Widget

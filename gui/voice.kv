#:import dp kivy.metrics.dp

<VoiceScreen>

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Voice Assistant"

        MDBoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(20)

            Widget

            MDIcon:
                icon: "microphone"
                icon_size: "100sp"
                pos_hint: {"center_x": 0.5}
                theme_text_color: "Custom"
                text_color: 0.0, 0.7, 1.0, 1

            MDLabel:
                text: "Voice Mode"
                halign: "center"
                font_style: "Headline"

            MDRaisedButton:
                text: "Start Listening"
                pos_hint: {"center_x": 0.5}

            Widget

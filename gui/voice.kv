#:import dp kivy.metrics.dp

<VoiceScreen>

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(20)

        canvas.before:
            Color:
                rgba: 0.04, 0.05, 0.09, 1
            Rectangle:
                pos: self.pos
                size: self.size

        MDLabel:
            text: "Voice Assistant"
            halign: "center"
            font_style: "H5"

        Widget

        MDIcon:
            icon: "microphone"
            icon_size: "90sp"
            pos_hint: {"center_x": .5}
            theme_text_color: "Custom"
            text_color: 0.0, 0.75, 1.0, 1

        MDLabel:
            text: "Tap the microphone to start speaking"
            halign: "center"

        Widget

        MDRaisedButton:
            text: "Start Listening"
            pos_hint: {"center_x": .5}

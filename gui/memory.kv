#:import dp kivy.metrics.dp

<MemoryScreen>

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(20)

        canvas.before:
            Color:
                rgba: 0.04, 0.05, 0.09, 1
            Rectangle:
                pos: self.pos
                size: self.size

        MDLabel:
            text: "Memory"
            halign: "center"
            font_style: "H5"

        MDCard:
            padding: dp(15)
            adaptive_height: True

            MDLabel:
                text: "Saved memories will appear here."
                halign: "center"

        Widget

        MDRaisedButton:
            text: "View Memory"
            pos_hint: {"center_x": .5}

#:import dp kivy.metrics.dp

<SettingsScreen>

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(15)

        canvas.before:
            Color:
                rgba: 0.04, 0.05, 0.09, 1
            Rectangle:
                pos: self.pos
                size: self.size

        MDLabel:
            text: "Settings"
            halign: "center"
            font_style: "H5"

        MDCard:
            orientation: "vertical"
            padding: dp(15)
            adaptive_height: True

            MDLabel:
                text: "Application Settings"
                halign: "center"

        MDRaisedButton:
            text: "Theme"

        MDRaisedButton:
            text: "AI Settings"

        MDRaisedButton:
            text: "About"

        Widget

#:import dp kivy.metrics.dp

<ToolsScreen>

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(15)

        canvas.before:
            Color:
                rgba: 0.04, 0.05, 0.09, 1
            Rectangle:
                pos: self.pos
                size: self.size

        MDLabel:
            text: "Tools"
            halign: "center"
            font_style: "H5"

        MDCard:
            orientation: "vertical"
            padding: dp(15)
            adaptive_height: True

            MDLabel:
                text: "Available Tools"
                halign: "center"

        MDRaisedButton:
            text: "Calculator"
            pos_hint: {"center_x": .5}

        MDRaisedButton:
            text: "Translator"
            pos_hint: {"center_x": .5}

        MDRaisedButton:
            text: "Weather"
            pos_hint: {"center_x": .5}

        Widget
